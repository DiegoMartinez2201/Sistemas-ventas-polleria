@model IEnumerable<capa.entMetodoDePago>

@{
    ViewData["Title"] = "Gestión de Métodos de Pago";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-secondary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0">
                            <i class="fas fa-credit-card me-2"></i>Gestión de Métodos de Pago
                        </h3>
                        <a href="@Url.Action("InsertarMetodoDePago", "MantenedorMetodoDePago")" class="btn btn-light">
                            <i class="fas fa-plus me-1"></i>Nuevo Método
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Nombre</th>
                                        <th scope="col">Estado</th>
                                        <th scope="col" class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.idMetodoPago</td>
                                            <td>
                                                <span class="fw-bold">@item.nombreMetodo</span>
                                            </td>
                                            <td>
                                                @if (item.estado == 1)
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactivo</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <a href="@Url.Action("EditarMetodoDePago", "MantenedorMetodoDePago", new { idMetodoPago = item.idMetodoPago })" 
                                                       class="btn btn-sm btn-outline-primary" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a href="@Url.Action("DeshabilitarMetodoDePago", "MantenedorMetodoDePago", new { idMetodoPago = item.idMetodoPago })" 
                                                       class="btn btn-sm btn-outline-danger" title="Deshabilitar"
                                                       onclick="return confirm('¿Está seguro de que desea deshabilitar este método de pago?')">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-credit-card fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No hay métodos de pago registrados</h5>
                            <p class="text-muted">Comience agregando un nuevo método</p>
                            <a href="@Url.Action("InsertarMetodoDePago", "MantenedorMetodoDePago")" class="btn btn-secondary">
                                <i class="fas fa-plus me-1"></i>Agregar Primer Método
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
